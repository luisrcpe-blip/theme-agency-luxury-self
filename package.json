{
  "name": "theme-agency-luxury-self",
  "version": "1.0.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "import:source": "node scripts/import-source-content.mjs && node scripts/import-source-properties.mjs",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "prepare:release": "node scripts/prepare-release.mjs",
    "prepare:demo": "node scripts/prepare-demo.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "test:editorial-runtime": "node scripts/test-editorial-runtime.mjs",
    "test:release-config": "node scripts/test-release-config.mjs",
    "check:links": "node scripts/check-links.mjs",
    "release": "npm run test:editorial-runtime && npm run test:release-config && npm run prepare:release && npm run verify:release && npm run check:links"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@vitejs/plugin-react": "5.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "6.4.2"
  },
  "engines": {
    "node": ">=20.19.0 <25"
  },
  "devDependencies": {
    "cheerio": "^1.2.0",
    "sharp": "^0.35.3"
  }
}
